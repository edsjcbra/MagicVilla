@model IEnumerable<VillaNumberDTO>

@{
    ViewData["Title"] = "Villa Number Home Page";
}
<div class="container p-4 border mt-3">
    <div class="row pb-2 mt-3">
        <div class="col">
            <h1 class="text-primary">Villa Number List</h1>
        </div>
        <div class="col text-end pt-1">
            <a asp-controller="VillaNumber" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-plus-square-fill"></i> Create New Villa Number</a>
        </div>
        <table class="table mt-3">
            <thead>
                <tr>
                    <th>
                        Villa Name
                    </th>
                    <th>
                        Villa Number
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Villa.Name</td>
                        <td>@item.VillaNo</td>
                        <td>
                            <a  asp-controller="VillaNumber" asp-action="Update" asp-route-id="@item.VillaNo" class="btn btn-success"><i class="bi bi-pencil-square"></i></a>
                            <a  asp-controller="VillaNumber" asp-action="Delete" asp-route-id="@item.VillaNo" class="btn btn-danger"><i class="bi bi-trash-fill"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>