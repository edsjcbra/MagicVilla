@model VillaNumberDeleteVM

@{
    ViewData["Title"] = "Delete Villa Number";
}
<div class="container p-4 border mt-3">
    <div class="row pb-2 mt-3">
        <div class="col">
            <h1 class="text-primary">Delete Villa Number</h1>
        </div>
        <form asp-action="DeleteVillaNumber">
            <input type="hidden" asp-for="@Model.VillaNumber.VillaNo"/>
            <br/>
            <div class="row">
                <div class="col-2">
                    <label asp-for="@Model.VillaNumber.VillaNo" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="@Model.VillaNumber.VillaNo" disabled class="form-control"/>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="@Model.VillaNumber.SpecialDetails" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="@Model.VillaNumber.SpecialDetails" disabled class="form-control"/>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="@Model.VillaNumber.VillaID" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="@Model.VillaNumber.VillaID" disabled class="form-control"/>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="d-inline-flex justify-content-center">
                    <a asp-controller="VillaNumber" asp-action="Index" class="btn-primary btn form-control" style="width: 300px; margin-right: 10px;">Back</a>
                    <br/>
                    <input type="submit" value="Delete" class="btn btn-danger form-control" style="width: 300px;"/>
                </div>
            </div>
        </form>
        
    </div>
    
</div>


@section Scripts
{
    <partial name="_ValidationScriptsPartial"/>
}
