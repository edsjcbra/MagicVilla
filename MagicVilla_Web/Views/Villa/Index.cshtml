@model IEnumerable<VillaDTO>

@{
    ViewData["Title"] = "Villa Home Page";
}
<div class="container p-4 border mt-3">
    <div class="row pb-2 mt-3">
        <div class="col">
            <h1 class="text-primary">Villa List</h1>
        </div>
        <div class="col text-end pt-1">
            <a asp-controller="Villa" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-plus-square-fill"></i> Create New Villa</a>
        </div>
        <table class="table mt-3">
            <thead>
                <tr>
                    <th>
                        Name
                    </th>
                    <th>
                        Occupancy
                    </th>
                    <th>
                        Price
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var villa in Model)
                {
                    <tr>
                        <td>@villa.Name</td>
                        <td>@villa.Occupancy</td>
                        <td>@((@villa.Rate).ToString("c"))</td>
                        <td>
                            <a  asp-controller="Villa" asp-action="Update" asp-route-id="@villa.Id" class="btn btn-success"><i class="bi bi-pencil-square"></i></a>
                            <a  asp-controller="Villa" asp-action="Delete" asp-route-id="@villa.Id" class="btn btn-danger"><i class="bi bi-trash-fill"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>