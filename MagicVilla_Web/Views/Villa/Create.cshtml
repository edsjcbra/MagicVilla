@model VillaCreateDTO

@{
    ViewData["Title"] = "Create Villa";
}
<div class="container p-4 border mt-3">
    <div class="row pb-2 mt-3">
        <div class="col">
            <h1 class="text-primary">Create Villa</h1>
        </div>
        <form asp-action="CreateVilla">
            <br/>
            <div class="row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="col-2">
                    <label asp-for="Name" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="Name" class="form-control"/>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="Rate" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="Rate" class="form-control"/>
                    <span asp-validation-for="Rate" class="text-danger"></span>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="Details" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <textarea asp-for="Details" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Details" class="text-danger"></span>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="ImageUrl" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="ImageUrl" class="form-control"/>
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="Occupancy" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="Occupancy" class="form-control"/>
                    <span asp-validation-for="Occupancy" class="text-danger"></span>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="Sqrft" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <input asp-for="Sqrft" class="form-control"/>
                    <span asp-validation-for="Sqrft" class="text-danger"></span>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="col-2">
                    <label asp-for="Amenity" class="control-label pt-2" style="font-size:20px;"></label>
                </div>
                <div class="col-10 pb-3">
                    <textarea asp-for="Amenity" class="form-control"></textarea>
                    <span asp-validation-for="Amenity" class="text-danger"></span>
                </div>
                @*-------------------------------------------------------------------------*@
                <div class="d-inline-flex justify-content-center">
                    <a asp-controller="Villa" asp-action="Index" class="btn-primary btn form-control" style="width: 300px; margin-right: 10px;">Back</a>
                    <br/>
                    <input type="submit" value="Create" class="btn btn-success form-control" style="width: 300px;"/>
                </div>
            </div>
        </form>
        
    </div>
    
</div>


@section Scripts
{
    <partial name="_ValidationScriptsPartial"/>
}
